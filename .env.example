# Copy to .env and fill in before deploy: cp .env.example .env

# Must match Reports Hub JWT secret (same as S.A.R.A.)
REPORTS_SECRET_KEY=your-reports-secret-here

# Active inference backend: vllm | sglang
INFERENCE_BACKEND=vllm
VLLM_BASE_URL=http://127.0.0.1:8000/v1
SGLANG_BASE_URL=http://127.0.0.1:30000/v1

# Model served by vLLM / SGLang (AWQ fits RTX 3060 12GB)
LLM_MODEL=Qwen/Qwen2.5-3B-Instruct-AWQ
EMBED_MODEL=BAAI/bge-small-en-v1.5

# Quantization profile label for metrics (awq | fp8 | gptq | none)
QUANTIZATION=awq
TENSOR_PARALLEL_SIZE=1

CHROMA_HOST=127.0.0.1
CHROMA_PORT=8100
RAG_DOCS_PATH=./data/docs
